    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter Web Launch with preview env",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}",
            "toolArgs": [
                "--dart-define=preview=true"
            ],
            "deviceId": "chrome"
        }
    ]
}